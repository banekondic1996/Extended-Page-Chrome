{
  "manifest_version": 3,
  "name": "Extended Page | New Tab Homepage",
  "version": "3.0.4",
  "description": "A beautiful new tab (homepage) page with widgets that can be powered by Extended History extension as option",
  "permissions": [
    "storage",
    "tabs",
    "bookmarks",
    "history",
    "alarms"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "chrome_url_overrides": {
    "newtab": "newtab.html"
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}